    DIM_TRADINGFLOORS ||--o{ DIM_EMPLOYEES : "floor_id"
    DIM_COMPANIES ||--o{ DIM_EMPLOYEES : "company_id"
    DIM_EMPLOYEES ||--o{ DIM_EMPLOYEES : "manager_employee_id (self-FK)"
    DIM_EMPLOYEES ||--o{ DIM_ACCOUNTS : "trader_id"
    DIM_ACCOUNTS ||--o{ FACT_TRADES : "account_id"
    DIM_EMPLOYEES ||--o{ FACT_TRADES : "trader_id"
    DIM_MARKETS ||--o{ FACT_TRADES : "market_id"
    DIM_SESSIONS ||--o{ FACT_TRADES : "session_id"
    DIM_ORDERTYPE ||--o{ FACT_TRADES : "order_type_id"
