{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/page/2.1.0/schema.json",
  "name": "p3trader",
  "displayName": "Trader Performance",
  "displayOption": "FitToPage",
  "height": 900,
  "width": 1600,
  "objects": {
    "background": [
      {
        "properties": {
          "color": {
            "solid": {
              "color": {
                "expr": {
                  "Literal": {
                    "Value": "'#0B0F19'"
                  }
                }
              }
            }
          },
          "transparency": {
            "expr": {
              "Literal": {
                "Value": "0D"
              }
            }
          }
        }
      }
    ],
    "outspace": [
      {
        "properties": {
          "color": {
            "solid": {
              "color": {
                "expr": {
                  "ThemeDataColor": {
                    "ColorId": 1,
                    "Percent": 0
                  }
                }
              }
            }
          }
        }
      }
    ],
    "outspacePane": [
      {
        "properties": {
          "foregroundColor": {
            "solid": {
              "color": {
                "expr": {
                  "Literal": {
                    "Value": "'#14E6C9'"
                  }
                }
              }
            }
          },
          "inputBoxColor": {
            "solid": {
              "color": {
                "expr": {
                  "Literal": {
                    "Value": "'#1F2937'"
                  }
                }
              }
            }
          },
          "backgroundColor": {
            "solid": {
              "color": {
                "expr": {
                  "Literal": {
                    "Value": "'#1F2937'"
                  }
                }
              }
            }
          }
        }
      }
    ],
    "filterCard": [
      {
        "properties": {
          "foregroundColor": {
            "solid": {
              "color": {
                "expr": {
                  "Literal": {
                    "Value": "'#14E6C9'"
                  }
                }
              }
            }
          },
          "backgroundColor": {
            "solid": {
              "color": {
                "expr": {
                  "Literal": {
                    "Value": "'#0B0F19'"
                  }
                }
              }
            }
          }
        },
        "selector": {
          "id": "Available"
        }
      }
    ]
  },
  "filterConfig": {
    "filters": [
      {
        "name": "pageDateCap",
        "field": {
          "Column": {
            "Expression": {
              "SourceRef": {
                "Entity": "dim_Date"
              }
            },
            "Property": "calendar_date"
          }
        },
        "type": "Advanced",
        "filter": {
          "Version": 2,
          "From": [
            {
              "Name": "d",
              "Entity": "dim_Date",
              "Type": 0
            }
          ],
          "Where": [
            {
              "Condition": {
                "Comparison": {
                  "ComparisonKind": 4,
                  "Left": {
                    "Column": {
                      "Expression": {
                        "SourceRef": {
                          "Source": "d"
                        }
                      },
                      "Property": "calendar_date"
                    }
                  },
                  "Right": {
                    "Literal": {
                      "Value": "datetime'2026-06-14T23:59:59'"
                    }
                  }
                }
              }
            }
          ]
        },
        "isHiddenInViewMode": true,
        "isLockedInViewMode": true
      },
      {
        "name": "drillCity",
        "field": {
          "Column": {
            "Expression": {
              "SourceRef": {
                "Entity": "dim_TradingFloors"
              }
            },
            "Property": "city"
          }
        },
        "type": "Categorical",
        "howCreated": "Drillthrough"
      },
      {
        "name": "drillTeam",
        "field": {
          "Column": {
            "Expression": {
              "SourceRef": {
                "Entity": "dim_Teams"
              }
            },
            "Property": "team_name"
          }
        },
        "type": "Categorical",
        "howCreated": "Drillthrough"
      },
      {
        "name": "drillTrader",
        "field": {
          "Column": {
            "Expression": {
              "SourceRef": {
                "Entity": "dim_Employees"
              }
            },
            "Property": "full_name"
          }
        },
        "type": "Categorical",
        "howCreated": "Drillthrough"
      }
    ]
  },
  "pageBinding": {
    "name": "bindTrader",
    "type": "Drillthrough",
    "parameters": [
      {
        "name": "pCity",
        "boundFilter": "drillCity",
        "fieldExpr": {
          "Column": {
            "Expression": {
              "SourceRef": {
                "Entity": "dim_TradingFloors"
              }
            },
            "Property": "city"
          }
        }
      },
      {
        "name": "pTeam",
        "boundFilter": "drillTeam",
        "fieldExpr": {
          "Column": {
            "Expression": {
              "SourceRef": {
                "Entity": "dim_Teams"
              }
            },
            "Property": "team_name"
          }
        }
      },
      {
        "name": "pTrader",
        "boundFilter": "drillTrader",
        "fieldExpr": {
          "Column": {
            "Expression": {
              "SourceRef": {
                "Entity": "dim_Employees"
              }
            },
            "Property": "full_name"
          }
        }
      }
    ]
  }
}