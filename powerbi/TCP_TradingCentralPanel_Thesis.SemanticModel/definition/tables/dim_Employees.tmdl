	/// Display label "First Last" for slicers and visuals bound to dim_Employees, so email is never exposed.
	/// Computed in the model (no SQL change); mirrors the trader name produced at the SQL layer.
	column full_name = dim_Employees[first_name] & " " & dim_Employees[last_name]
